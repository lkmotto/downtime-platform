# DownTime Backend — Environment Variables
# Copy this to .env and fill in your API keys

# Ticketmaster Discovery API (free — 5,000 calls/day)
# Get key at: https://developer.ticketmaster.com/
TM_API_KEY=

# SeatGeek API (free — no published cap)
# Get key at: https://seatgeek.com/account/develop
SG_CLIENT_ID=

# SerpAPI for Google Events (free — 250 searches/month)
# Get key at: https://serpapi.com/
SERPAPI_KEY=

# OpenTripMap API (free — 5,000 calls/day)
# Get key at: https://opentripmap.io/
OTM_API_KEY=

# Server settings
PORT=8000
HOST=0.0.0.0
ENV=development

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Cache TTL in seconds (default 6 hours)
CACHE_TTL=21600

# Fetch settings
FETCH_DAYS_AHEAD=14
FETCH_PAGE_SIZE=100

# Sentry error tracking (leave blank to disable)
SENTRY_DSN=
DEPLOY_ENV=prd
